# 自动处理文本文件的换行符
* text=auto

# 明确指定某些文件类型使用 LF (推荐代码文件统一使用 LF)
*.js text eol=lf
*.ts text eol=lf
*.vue text eol=lf
*.json text eol=lf
*.md text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf

# 图片等二进制文件保持原样
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
