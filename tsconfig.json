{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": [
            "ES2020",
            "DOM",
            "DOM.Iterable"
        ],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "jsx": "preserve",
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "docs/.vuepress/*"
            ]
        }
    },
    "include": [
        "docs/.vuepress/**/*.ts",
        "docs/.vuepress/**/*.vue"
    ],
    "exclude": [
        "node_modules"
    ]
}